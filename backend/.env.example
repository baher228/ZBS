APP_NAME=ZBS API
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
LLM_PROVIDER=mock
LLM_MODEL=mock-gtm-v1
AGENT_CACHE_ENABLED=true
AGENT_CACHE_MAX_ENTRIES=500
LLM_API_KEY=
PYDANTIC_AI_GATEWAY_API_KEY=
PYDANTIC_AI_GATEWAY_BASE_URL=
FAL_API_KEY=
MUBIT_ENABLED=true
MUBIT_API_KEY=
MUBIT_AGENT_ID=zbs-agent
MUBIT_ENDPOINT=https://api.mubit.ai
MUBIT_HTTP_ENDPOINT=https://api.mubit.ai
MUBIT_GRPC_ENDPOINT=grpc.api.mubit.ai:443
MUBIT_TRANSPORT=auto
