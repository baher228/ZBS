            "action_id": "onb_highlight_form",
            "say": "First, the founder provides company context here."
          },
          {
            "page_id": "dashboard",
            "action_id": "dash_nav_agents",
            "say": "That context powers the operator room and specialist agents."
          },
          {
            "page_id": "agents",
            "action_id": "agents_nav_demo",
            "say": "From the agent lab, we open the prospect-facing demo room."
          },
          {
            "page_id": "demo",
            "action_id": "demo_highlight_input",
            "say": "Buyers can ask questions or use the suggested prompts."
          }
        ]
      },
