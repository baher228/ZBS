    "approved_answers": [
      {
        "topic": "What does the founder need to provide?",
        "answer": "A product or staging URL, sandbox credentials when needed, target persona, demo goals, a short walkthrough, approved Q&A, CTA, and qualification questions.",
        "source": "Founder-provided approved_qa"
      },
      {
        "topic": "Should the runtime click the real app directly?",
        "answer": "The MVP should use an approved manifest and visual event playback. Playwright is better for setup-time extraction and validation. Live app control can come later for approved low-risk paths.",
        "source": "Founder-provided approved_qa"
      },
      {
